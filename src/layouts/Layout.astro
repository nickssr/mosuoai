---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '摸索AI - AI Agent 教程与实战' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | 摸索AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="header">
      <nav class="nav">
        <a href="/" class="logo">
          <span class="logo-icon">🔮</span>
          <span class="logo-text">摸索AI</span>
        </a>
        <div class="nav-links">
          <a href="/tutorials">教程</a>
          <a href="/blog">博客</a>
          <a href="/about">关于</a>
        </div>
      </nav>
    </header>
    <main class="main">
      <slot />
    </main>
    <footer class="footer">
      <p>© 2026 摸索AI - Made with Astro & Cloudflare Pages</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* 主色调 - 紫色渐变 */
    --primary: #7c3aed;
    --primary-light: #8b5cf6;
    --primary-dark: #6d28d9;
    --accent: #a78bfa;
    
    /* 背景色 */
    --bg: #0a0a0f;
    --bg-card: #12121a;
    --bg-card-hover: #1a1a25;
    
    /* 文字 */
    --text: #f0f0f5;
    --text-muted: #9ca3af;
    --text-dim: #6b7280;
    
    /* 边框 */
    --border: #27273a;
    --border-light: #3f3f5a;
    
    /* 阴影 */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -2px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -4px rgba(0, 0, 0, 0.4);
    --shadow-glow: 0 0 40px rgba(124, 58, 237, 0.3);
    
    /* 圆角 */
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
    --radius-xl: 24px;
  }
  
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  
  html {
    font-size: 16px;
    scroll-behavior: smooth;
  }
  
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }
  
  a {
    color: var(--primary-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  
  a:hover {
    color: var(--accent);
  }
  
  /* 渐变背景 */
  .gradient-bg {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  }
  
  /* 文字渐变 */
  .text-gradient {
    background: linear-gradient(135deg, var(--primary-light) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<style>
  /* Header */
  .header {
    border-bottom: 1px solid var(--border);
    padding: 1rem 2rem;
    position: sticky;
    top: 0;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
    z-index: 1000;
  }
  
  .nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text);
  }
  
  .logo-icon {
    font-size: 1.75rem;
  }
  
  .logo:hover {
    color: var(--primary-light);
  }
  
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  
  .nav-links a {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.5rem 0;
    position: relative;
  }
  
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary-light);
    transition: width 0.3s ease;
  }
  
  .nav-links a:hover {
    color: var(--text);
  }
  
  .nav-links a:hover::after {
    width: 100%;
  }
  
  /* Main */
  .main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    min-height: calc(100vh - 180px);
  }
  
  /* Footer */
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.9rem;
  }
  
  /* 移动端 */
  @media (max-width: 768px) {
    .header {
      padding: 0.75rem 1rem;
    }
    
    .nav-links {
      gap: 1rem;
    }
    
    .nav-links a {
      font-size: 0.875rem;
    }
    
    .main {
      padding: 1rem;
    }
  }
</style>
