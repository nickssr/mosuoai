---
import { Tag, ArrowLeft } from 'lucide-astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Props {
  tag: string;
}

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const allTags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return allTags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const filteredPosts = allPosts
  .filter((post) => post.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`#${tag}`} description={`包含标签「${tag}」的所有文章`}>
  <div class="tag-page">
    <header class="tag-header">
      <Tag size={48} class="tag-icon" />
      <h1 class="tag-title">{tag}</h1>
      <span class="tag-count">{filteredPosts.length} 篇文章</span>
    </header>

    {filteredPosts.length === 0 ? (
      <div class="empty-state">
        <p>该标签下还没有文章</p>
      </div>
    ) : (
      <div class="post-grid">
        {filteredPosts.map((post) => (
          <article class="post-card">
            <a href={`/posts/${post.slug}`} class="card-link">
              <div class="card-content">
                <div class="card-meta">
                  <span class="category-badge category-{post.data.category}">
                    {post.data.category}
                  </span>
                  <span class="card-date">
                    {post.data.pubDate.toLocaleDateString('zh-CN', {
                      month: 'short',
                      day: 'numeric',
                    })}
                  </span>
                </div>
                <h3 class="card-title">{post.data.title}</h3>
                <p class="card-desc">{post.data.description}</p>
                <div class="card-tags">
                  {post.data.tags.slice(0, 3).map((t) => (
                    <a href={`/tags/${t}`} class="tag">#{t}</a>
                  ))}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    )}

    <div class="back-to-home">
      <a href="/" class="back-link">
        <ArrowLeft size={16} style="display:inline-block;vertical-align:middle;margin-right:4px;" />
        返回首页
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .tag-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: var(--space-10) var(--space-6);
  }

  /* Tag Header */
  .tag-header {
    text-align: center;
    margin-bottom: var(--space-10);
    padding: var(--space-8);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .tag-icon {
    color: var(--color-primary);
    display: block;
    margin-bottom: var(--space-4);
  }

  .tag-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .tag-count {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  /* Post Grid */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  /* Post Card */
  .post-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .post-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 212, 224, 0.15);
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  .card-content {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .category-badge {
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .category-tutorial {
    background: rgba(0, 212, 224, 0.15);
    color: var(--color-primary);
    border: 1px solid rgba(0, 212, 224, 0.3);
  }

  .category-review {
    background: rgba(139, 92, 246, 0.15);
    color: var(--color-accent);
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  .category-case-study {
    background: rgba(16, 185, 129, 0.15);
    color: var(--color-success);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .category-news {
    background: rgba(59, 130, 246, 0.15);
    color: var(--color-info);
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .card-date {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
    margin: 0;
  }

  .card-desc {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-2);
  }

  .tag {
    color: var(--color-primary);
    background: rgba(0, 212, 224, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid rgba(0, 212, 224, 0.2);
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .tag:hover {
    background: rgba(0, 212, 224, 0.2);
    color: var(--color-primary-dark);
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-6);
    color: var(--color-text-muted);
  }

  /* Back Link */
  .back-to-home {
    text-align: center;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .tag-page {
      padding: var(--space-6) var(--space-4);
    }

    .tag-title {
      font-size: 1.5rem;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
