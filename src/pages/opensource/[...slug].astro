---
import { Calendar, User, ArrowLeft, ArrowRight, Tag, Clock } from 'lucide-astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { slug } from 'github-slugger';

interface Props {
  params: {
    slug: string;
  };
}

const allOpensource = await getCollection('opensource');

function getOpensourceFromSlug(slugStr: string) {
  return allOpensource.find((item) => item.id === slugStr);
}

export async function getStaticPaths() {
  const items = await getCollection('opensource', ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.id },
    props: { opensource: item },
  }));
}

const { slug: slugParam } = Astro.params;
const item = getOpensourceFromSlug(slugParam);

if (!item) {
  return Astro.redirect('/opensource');
}

const { Content } = await render(item);

// 计算阅读时长
const textContent = item.body?.replace(/[#*_`~\[\]()<>]/g, '') || '';
const wordCount = textContent.length;
const readingTime = Math.ceil(wordCount / 200) || 1;

// 提取标题用于目录（如果body有toc属性则使用，否则正则提取）
const headings = item.body?.toc ? item.body.toc.map((t: { text: string; depth: number; slug: string }) => ({
  text: t.text,
  depth: t.depth,
  slug: slug(t.text),
})) : [];

// 如果toc为空，用正则提取
const headingRegex = /^(#{2,3})\s+(.+)$/gm;
let m;
while ((m = headingRegex.exec(item.body || '')) !== null) {
  const text = m[2].trim();
  if (!headings.find((h: { text: string }) => h.text === text)) {
    headings.push({ depth: m[1].length, slug: slug(text), text });
  }
}

// 获取上一篇和下一篇
const sortedItems = allOpensource
  .filter((i) => !i.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedItems.findIndex((i) => i.id === item.id);
const prevItem = currentIndex < sortedItems.length - 1 ? sortedItems[currentIndex + 1] : null;
const nextItem = currentIndex > 0 ? sortedItems[currentIndex - 1] : null;

const defaultThumb = '/og-default.svg';
---

<BaseLayout title={item.data.title} description={item.data.description}>
  <article class="article-page">
    <header class="article-header opensource-header">
      <div class="opensource-glow"></div>
      <a href="/opensource" class="back-link">
        <ArrowLeft size={14} />
        返回开源
      </a>
      <h1 class="article-title">{item.data.title}</h1>
      <div class="article-meta">
        <span class="meta-item">
          <User size={14} />
          {item.data.author || 'MosuoAI'}
        </span>
        <span class="meta-item">
          <Calendar size={14} />
          {item.data.pubDate.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </span>
        <span class="meta-item">
          <Clock size={14} />
          {readingTime} 分钟阅读
        </span>
      </div>
      {item.data.tags && item.data.tags.length > 0 && (
        <div class="article-tags">
          {item.data.tags.map((tag) => (
            <span class="article-tag opensource-tag">
              <Tag size={12} />
              {tag}
            </span>
          ))}
        </div>
      )}

      {item.data.heroImage && (
        <div class="article-hero">
          <img src={item.data.heroImage} alt={item.data.title} />
        </div>
      )}
    </header>

    <div class="article-content-wrapper">
      <nav class="floating-toc">
        <TableOfContents headings={headings} />
      </nav>
      <div class="article-body">
        <Content />
      </div>
      <aside class="article-sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">热门文章</h3>
          <ul class="popular-list">
            <li><a href="/opensource/2026-04-23-langgraph-vs-langchain" class="popular-link">LangGraph vs LangChain：Agent 开发范式之争</a></li>
            <li><a href="/opensource/2026-04-22-mcp-protocol-guide" class="popular-link">MCP 协议完全指南</a></li>
            <li><a href="/tutorials/2026-04-22-ai-agent-getting-started" class="popular-link">AI Agent 开发入门指南</a></li>
          </ul>
        </div>
        <div class="sidebar-section">
          <h3 class="sidebar-title">热门标签</h3>
          <div class="tag-cloud">
            {item.data.tags?.map((tag) => (
              <a href={`/tags/${tag}`} class="tag-pill">
                {tag}
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>

    <footer class="article-footer">
      {(prevItem || nextItem) && (
        <nav class="article-nav">
          {prevItem && (
            <a href={`/opensource/${prevItem.id}`} class="nav-item nav-prev">
              <span class="nav-label">
                <ArrowLeft size={14} />
                上一篇
              </span>
              <span class="nav-title">{prevItem.data.title}</span>
            </a>
          )}
          {nextItem && (
            <a href={`/opensource/${nextItem.id}`} class="nav-item nav-next">
              <span class="nav-label">
                下一篇
                <ArrowRight size={14} />
              </span>
              <span class="nav-title">{nextItem.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </footer>
  </article>
</BaseLayout>

<style>
  /* 开源页特有样式：渐变头部 + 标签样式 */
  .opensource-header {
    position: relative;
    overflow: hidden;
  }

  .opensource-glow {
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    pointer-events: none;
  }

  .article-tag.opensource-tag {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(124, 58, 237, 0.1) 100%);
    color: #a78bfa;
    border-color: rgba(139, 92, 246, 0.3);
  }

  .article-tag {
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .article-tag:hover {
    background: rgba(0, 212, 224, 0.2);
    border-color: var(--color-primary);
  }

  .opensource-header .article-tag:hover {
    background: rgba(139, 92, 246, 0.2);
    border-color: #a78bfa;
  }
</style>
