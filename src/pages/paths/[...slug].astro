---
import { Map, Clock, CheckCircle, ArrowLeft, ArrowRight } from 'lucide-astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPaths = await getCollection('paths');
  return allPaths.map((path) => ({
    params: { slug: path.slug },
    props: { path },
  }));
}

const { path } = Astro.props;
const { title, description, level, duration, steps } = path.data;

// 难度配置
const difficultyConfig = {
  beginner: { label: '入门', color: 'var(--color-success)' },
  intermediate: { label: '进阶', color: 'var(--color-warning)' },
  advanced: { label: '高级', color: 'var(--color-error)' },
};

const difficulty = difficultyConfig[level as keyof typeof difficultyConfig];

// 上一篇/下一篇
const allPaths = await getCollection('paths', ({ data }) => !data.draft);
const currentIndex = allPaths.findIndex((p) => p.id === path.id);
const prevPath = currentIndex > 0 ? allPaths[currentIndex - 1] : null;
const nextPath = currentIndex < allPaths.length - 1 ? allPaths[currentIndex + 1] : null;
---

<BaseLayout title={title} description={description}>
  <article class="path-page">
    <header class="page-header">
      <a href="/paths" class="back-link">
        <ArrowLeft size={18} />
        返回路径列表
      </a>
      <div class="header-content">
        <Map size={48} class="header-icon" style={`color: ${difficulty.color}`} />
        <h1 class="page-title">{title}</h1>
        <p class="page-desc">{description}</p>
        <div class="meta-tags">
          <span class="meta-tag" style={`background: ${difficulty.color}20; color: ${difficulty.color}`}>
            {difficulty.label}
          </span>
          {duration && (
            <span class="meta-tag">
              <Clock size={14} />
              {duration}
            </span>
          )}
        </div>
      </div>
    </header>

    {steps && steps.length > 0 && (
      <div class="steps-container">
        <h2 class="steps-title">
          <CheckCircle size={20} />
          学习步骤
        </h2>
        <div class="steps-list">
          {steps.map((step, index) => (
            <div class="step-item">
              <div class="step-number">{index + 1}</div>
              <div class="step-content">
                <h3 class="step-title">{step.title}</h3>
                {step.description && <p class="step-desc">{step.description}</p>}
                {step.content && step.content.length > 0 && (
                  <ul class="step-topics">
                    {step.content.map((topic) => (
                      <li>{topic}</li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="path-content">
      <slot />
    </div>

    <nav class="pagination">
      {prevPath ? (
        <a href={`/paths/${prevPath.slug}`} class="pagination-link prev">
          <ArrowLeft size={18} />
          <span class="pagination-label">上一个路径</span>
          <span class="pagination-title">{prevPath.data.title}</span>
        </a>
      ) : (
        <div class="pagination-placeholder"></div>
      )}
      {nextPath ? (
        <a href={`/paths/${nextPath.slug}`} class="pagination-link next">
          <span class="pagination-label">下一个路径</span>
          <span class="pagination-title">{nextPath.data.title}</span>
          <ArrowRight size={18} />
        </a>
      ) : (
        <div class="pagination-placeholder"></div>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .path-page {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: var(--space-12);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: var(--space-4);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .header-content {
    text-align: center;
  }

  .header-icon {
    margin-bottom: 1rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--space-3);
    color: var(--color-text-primary);
  }

  .page-desc {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
    margin-bottom: var(--space-4);
  }

  .meta-tags {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
  }

  .meta-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
  }

  /* Steps Section */
  .steps-container {
    margin-bottom: var(--space-10);
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .steps-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-5);
  }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .step-item {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-bg-primary);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .step-number {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--color-primary);
    color: white;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 50%;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .step-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .step-topics {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .step-topics li {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    padding: 0.25rem 0;
    padding-left: 1rem;
    position: relative;
  }

  .step-topics li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  /* Path Content (Markdown) */
  .path-content {
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  .path-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .path-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .path-content :global(p) {
    margin-bottom: var(--space-4);
    line-height: 1.7;
  }

  .path-content :global(ul),
  .path-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: 1.5rem;
  }

  .path-content :global(li) {
    margin-bottom: 0.5rem;
  }

  /* Pagination */
  .pagination {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .pagination-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: var(--space-4);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .pagination-link:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-tertiary);
  }

  .pagination-link.prev {
    align-items: flex-start;
  }

  .pagination-link.next {
    align-items: flex-end;
    text-align: right;
  }

  .pagination-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .pagination-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .pagination-placeholder {
    /* Empty placeholder for alignment */
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 1.5rem;
    }

    .steps-container {
      padding: var(--space-4);
    }

    .step-item {
      flex-direction: column;
      align-items: flex-start;
    }

    .pagination {
      grid-template-columns: 1fr;
    }
  }
</style>
