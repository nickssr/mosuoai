---
import { Map, Clock, TrendingUp, ArrowRight } from 'lucide-astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPaths = await getCollection('paths', ({ data }) => !data.draft);

// 难度配置
const difficultyConfig = {
  beginner: { label: '入门', color: 'var(--color-success)', icon: TrendingUp },
  intermediate: { label: '进阶', color: 'var(--color-warning)', icon: TrendingUp },
  advanced: { label: '高级', color: 'var(--color-error)', icon: TrendingUp },
};
---

<BaseLayout title="学习路径" description="系统化的 AI Agent 学习路径，从入门到精通">
  <div class="paths-page">
    <header class="page-header">
      <Map size={64} class="header-icon" />
      <h1 class="page-title">学习路径</h1>
      <p class="page-subtitle">系统化的学习路线，带你从入门到精通</p>
    </header>

    {allPaths.length === 0 ? (
      <div class="empty-state">
        <Map size={64} class="empty-icon" />
        <p>暂无学习路径，敬请期待...</p>
      </div>
    ) : (
      <div class="paths-grid">
        {allPaths.map((path) => {
          const difficulty = difficultyConfig[path.data.level as keyof typeof difficultyConfig];
          const IconComponent = difficulty.icon;
          return (
            <article class="path-card">
              <a href={`/paths/${path.slug}`} class="card-link"></a>
              <div class="card-glow"></div>
              <div class="card-content">
                <div class="card-header">
                  <span
                    class="difficulty-badge"
                    style={`background: ${difficulty.color}20; color: ${difficulty.color};`}
                  >
                    <IconComponent size={12} />
                    {difficulty.label}
                  </span>
                  {path.data.duration && (
                    <span class="duration-badge">
                      <Clock size={14} />
                      {path.data.duration}
                    </span>
                  )}
                </div>
                <h2 class="card-title">{path.data.title}</h2>
                <p class="card-desc">{path.data.description}</p>
                {path.data.steps && path.data.steps.length > 0 && (
                  <div class="steps-preview">
                    <div class="steps-label">学习内容</div>
                    <ul class="steps-list">
                      {path.data.steps.slice(0, 3).map((step) => (
                        <li>
                          <span class="step-title">{step.title}</span>
                        </li>
                      ))}
                      {path.data.steps.length > 3 && (
                        <li class="more-item">还有 {path.data.steps.length - 3} 个步骤...</li>
                      )}
                    </ul>
                  </div>
                )}
                <div class="card-footer">
                  <span class="read-more">
                    开始学习 <ArrowRight size={14} />
                  </span>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .paths-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .header-icon {
    color: var(--color-primary);
    margin-bottom: 1rem;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }

  .paths-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }

  .path-card {
    position: relative;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .path-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(0, 212, 224, 0.15);
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(0, 212, 224, 0.08) 0%, transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .path-card:hover .card-glow {
    opacity: 1;
  }

  .card-content {
    position: relative;
    z-index: 1;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    align-items: center;
  }

  .difficulty-badge {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .duration-badge {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 500;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
    line-height: 1.4;
  }

  .card-desc {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: var(--space-4);
  }

  .steps-preview {
    margin-bottom: var(--space-4);
    padding: var(--space-3);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
  }

  .steps-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-2);
  }

  .steps-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .steps-list li {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    padding: 0.35rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .steps-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .more-item {
    font-style: italic;
    color: var(--color-text-muted);
  }

  .card-footer {
    margin-top: auto;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
    transition: gap var(--transition-fast);
  }

  .path-card:hover .read-more {
    gap: 0.5rem;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-8);
    background: var(--color-bg-secondary);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-secondary);
  }

  .empty-icon {
    color: var(--color-text-muted);
    opacity: 0.5;
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 1.875rem;
    }

    .paths-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
