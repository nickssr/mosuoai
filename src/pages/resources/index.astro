---
import { ExternalLink, Wrench, LayoutGrid, Globe, BookOpen, Users } from 'lucide-astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const allResources = await getCollection('resources', ({ data }) => !data.draft);

// 分类配置
const categoryConfig = {
  tools: { label: '工具', icon: Wrench, color: '#00D4E0' },
  frameworks: { label: '框架', icon: LayoutGrid, color: '#8B5CF6' },
  platforms: { label: '平台', icon: Globe, color: '#3B82F6' },
  learning: { label: '学习', icon: BookOpen, color: '#F59E0B' },
  community: { label: '社区', icon: Users, color: '#10B981' },
};

// 按分类分组
const groupedResources = Object.entries(categoryConfig).map(([key, config]) => ({
  key,
  ...config,
  items: allResources.filter((r) => r.data.category === key),
})).filter((group) => group.items.length > 0);
---

<BaseLayout title="资源导航" description="精选 AI Agent 开发工具和资源">
  <PageHero title="资源导航" description="精选 AI Agent 开发工具、框架和学习资源" />

  <div class="resources-page">
    <section class="categories-section">
      {groupedResources.map((group) => {
        const IconComponent = group.icon;
        return (
          <div class="category-group">
            <h2 class="category-title">
              <IconComponent size={16} style={`color: ${group.color}`} />
              {group.label}
              <span class="category-count">{group.items.length}</span>
            </h2>
            <div class="resource-grid">
              {group.items.map((resource) => (
                <a href={resource.data.url} target="_blank" rel="noopener noreferrer" class="resource-card">
                  <div class="resource-content">
                    <div class="resource-header">
                      <h3 class="resource-title">{resource.data.title}</h3>
                      <ExternalLink size={12} class="link-icon" />
                    </div>
                    <p class="resource-desc">{resource.data.description}</p>
                    {resource.data.tags.length > 0 && (
                      <div class="resource-tags">
                        {resource.data.tags.slice(0, 3).map((tag) => (
                          <span class="tag">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </section>
  </div>
</BaseLayout>

<style>
  .resources-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 2rem;
  }

  .categories-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .category-group {
    margin-bottom: 1rem;
  }

  .category-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-primary);
  }

  .category-count {
    background: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 12px;
    margin-left: 0.5rem;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.75rem;
  }

  .resource-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.75rem;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .resource-card:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-tertiary);
    transform: translateY(-1px);
  }

  .resource-content {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .resource-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.35rem;
  }

  .resource-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-primary);
    flex: 1;
    line-height: 1.3;
  }

  .link-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .resource-desc {
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .resource-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .tag {
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    background: rgba(0, 212, 224, 0.1);
    color: var(--color-primary);
    border-radius: 8px;
    font-weight: 500;
    border: 1px solid rgba(0, 212, 224, 0.2);
  }

  @media (max-width: 1200px) {
    .resource-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 900px) {
    .resource-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .resources-page {
      padding: 0 1rem 1rem;
    }

    .resource-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .resource-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
