---
import { Icon } from 'lucide-astro';
import { BookOpen, Construction, Calendar, User } from 'lucide-astro/icons';
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const sortedTutorials = tutorials.sort((a, b) => b.data.order - a.data.order);
---

<Layout title="教程" description="AI Agent 开发教程 - OpenClaw、Hermes Agent 等工具实战指南">
  <section class="page-header">
    <Icon name={BookOpen} size={64} class="header-icon" />
    <h1>全部教程</h1>
    <p class="subtitle">系统学习 AI Agent 开发，从入门到实战</p>
  </section>

  {sortedTutorials.length === 0 ? (
    <div class="empty-state">
      <Icon name={Construction} size={64} class="empty-icon" />
      <h2>教程正在筹备中</h2>
      <p>精彩内容即将上线，敬请期待...</p>
    </div>
  ) : (
    <div class="tutorial-list">
      {sortedTutorials.map((tutorial, index) => (
        <article class="tutorial-item" style={`--delay: ${index * 0.1}s`}>
          <div class="card-glow"></div>
          <div class="tutorial-number">{index + 1}</div>
          <div class="content">
            <div class="tags">
              {tutorial.data.tags.slice(0, 3).map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <h2>
              <a href={`/tutorials/${tutorial.id}`}>{tutorial.data.title}</a>
            </h2>
            <p class="description">{tutorial.data.description}</p>
            <div class="meta">
              <span class="meta-item">
                <Icon name={Calendar} size={14} style="display:inline-block;vertical-align:middle;margin-right:4px;" />
                {tutorial.data.pubDate.toLocaleDateString('zh-CN')}
              </span>
              <span class="meta-item">
                <Icon name={User} size={14} style="display:inline-block;vertical-align:middle;margin-right:4px;" />
                {tutorial.data.author}
              </span>
            </div>
          </div>
          <div class="arrow">
            <span>→</span>
          </div>
        </article>
      ))}
    </div>
  )}
</Layout>

<style>
  .page-header {
    text-align: center;
    padding: 3rem 0;
    margin-bottom: 2rem;
  }
  
  .header-icon {
    color: var(--primary-light);
    margin-bottom: 1rem;
    animation: float 3s ease-in-out infinite;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  
  .subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto;
  }
  
  .tutorial-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .tutorial-item {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    transition: all 0.3s ease;
    animation: slideIn 0.5s ease backwards;
    animation-delay: var(--delay);
  }
  
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(124, 58, 237, 0.08) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    border-radius: var(--radius-lg);
  }
  
  .tutorial-item:hover {
    border-color: var(--primary);
    transform: translateX(8px);
    box-shadow: var(--shadow-md), 0 0 20px rgba(124, 58, 237, 0.15);
  }
  
  .tutorial-item:hover .card-glow {
    opacity: 1;
  }
  
  .tutorial-item:hover .arrow {
    opacity: 1;
    transform: translateX(4px);
  }
  
  .tutorial-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary);
    opacity: 0.5;
    min-width: 2.5rem;
    text-align: center;
  }
  
  .content {
    flex: 1;
    min-width: 0;
  }
  
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  
  .tag {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2) 0%, rgba(139, 92, 246, 0.1) 100%);
    color: var(--primary-light);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid rgba(124, 58, 237, 0.3);
  }
  
  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  
  h2 a {
    color: var(--text);
    transition: color 0.2s ease;
  }
  
  h2 a:hover {
    color: var(--primary-light);
  }
  
  .description {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  
  .icon {
    color: var(--text-dim);
  }
  
  .arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--bg-card-hover);
    color: var(--primary-light);
    font-size: 1.25rem;
    opacity: 0;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }
  
  .empty-state {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  
  .empty-icon {
    color: var(--text-muted);
    opacity: 0.5;
    margin-bottom: 1rem;
  }
  
  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  
  .empty-state p {
    color: var(--text-muted);
  }
  
  @media (max-width: 768px) {
    h1 {
      font-size: 2rem;
    }
    
    .tutorial-item {
      flex-direction: column;
      gap: 1rem;
    }
    
    .tutorial-item:hover {
      transform: translateY(-4px);
    }
    
    .arrow {
      display: none;
    }
    
    .tutorial-number {
      display: none;
    }
  }
</style>
