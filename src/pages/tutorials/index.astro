---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const sortedTutorials = tutorials.sort((a, b) => b.data.order - a.data.order);
---

<Layout title="教程" description="AI Agent 开发教程 - OpenClaw、Hermes Agent 等工具实战指南">
  <h1>教程</h1>
  <p class="intro">系统学习 AI Agent 开发，从入门到实战</p>
  
  <div class="tutorial-list">
    {sortedTutorials.map((tutorial) => (
      <article class="tutorial-item">
        <div class="content">
          <h2>
            <a href={`/tutorials/${tutorial.id}`}>{tutorial.data.title}</a>
          </h2>
          <p class="description">{tutorial.data.description}</p>
          <div class="meta">
            <span class="date">{tutorial.data.pubDate.toLocaleDateString('zh-CN')}</span>
            <span class="author">by {tutorial.data.author}</span>
            {tutorial.data.tags.length > 0 && (
              <div class="tags">
                {tutorial.data.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</Layout>

<style>
  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  
  .intro {
    color: #888;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }
  
  .tutorial-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .tutorial-item {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  
  .tutorial-item:hover {
    border-color: var(--accent);
  }
  
  .tutorial-item h2 {
    margin-bottom: 0.75rem;
  }
  
  .tutorial-item h2 a {
    color: var(--text);
  }
  
  .tutorial-item h2 a:hover {
    color: var(--accent);
  }
  
  .description {
    color: #aaa;
    margin-bottom: 1rem;
  }
  
  .meta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    font-size: 0.85rem;
    color: #888;
    flex-wrap: wrap;
  }
  
  .tags {
    display: flex;
    gap: 0.5rem;
  }
  
  .tag {
    background: var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
  }
</style>
