---
import { BookOpen, Calendar, Clock, ArrowRight } from 'lucide-astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);
const sortedTutorials = allTutorials.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 难度配置
const difficultyConfig = {
  beginner: { label: '入门', color: 'var(--color-success)' },
  intermediate: { label: '进阶', color: 'var(--color-warning)' },
  advanced: { label: '高级', color: 'var(--color-error)' },
};

// 分类中文名
const categoryNames: Record<string, string> = {
  setup: '环境配置',
  'skill-dev': 'Skill 开发',
  memory: '记忆系统',
  proactivity: '主动性',
  integration: '集成',
};
---

<BaseLayout title="部署教程" description="AI Agent 部署和开发教程">
  <div class="tutorials-page">
    <header class="page-header">
      <BookOpen size={48} class="header-icon" />
      <h1 class="page-title">部署教程</h1>
      <p class="page-subtitle">从入门到精通，系统的 AI Agent 开发教程</p>
    </header>

    {sortedTutorials.length === 0 ? (
      <div class="empty-state">
        <BookOpen size={64} class="empty-icon" />
        <p>暂无教程，敬请期待...</p>
      </div>
    ) : (
      <div class="tutorials-grid">
        {sortedTutorials.map((tutorial) => {
          const difficulty = difficultyConfig[tutorial.data.difficulty];
          return (
            <article class="tutorial-card">
              <a href={`/tutorials/${tutorial.slug}`} class="card-link"></a>
              <div class="card-glow"></div>
              <div class="card-content">
                <div class="card-header">
                  <span class="category-badge">{categoryNames[tutorial.data.category]}</span>
                  <span
                    class="difficulty-badge"
                    style={`background: ${difficulty.color}20; color: ${difficulty.color};`}
                  >
                    {difficulty.label}
                  </span>
                </div>
                {tutorial.data.heroImage && (
                  <div class="card-hero">
                    <img src={tutorial.data.heroImage} alt={tutorial.data.title} loading="lazy" />
                  </div>
                )}
                <h2 class="card-title">{tutorial.data.title}</h2>
                <p class="card-desc">{tutorial.data.description}</p>
                <div class="card-meta">
                  {tutorial.data.duration && (
                    <span class="meta-item">
                      <Clock size={14} />
                      {tutorial.data.duration}
                    </span>
                  )}
                  <time datetime={tutorial.data.pubDate.toISOString()} class="meta-item">
                    <Calendar size={14} />
                    {tutorial.data.pubDate.toLocaleDateString('zh-CN', {
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                </div>
                <div class="card-footer">
                  <span class="read-more">
                    开始学习 <ArrowRight size={14} />
                  </span>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .tutorials-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .header-icon {
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 1.125rem;
  }

  .tutorials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .tutorial-card {
    position: relative;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .tutorial-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(0, 212, 224, 0.15);
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(0, 212, 224, 0.08) 0%, transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .tutorial-card:hover .card-glow {
    opacity: 1;
  }

  .card-content {
    position: relative;
    z-index: 1;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .category-badge {
    background: rgba(0, 212, 224, 0.15);
    color: var(--color-primary);
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid rgba(0, 212, 224, 0.3);
  }

  .difficulty-badge {
    padding: 0.25rem 0.6rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .card-hero {
    width: 100%;
    height: 160px;
    margin: 0 calc(-1 * var(--space-5)) var(--space-4);
    overflow: hidden;
  }

  .card-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
    line-height: 1.4;
  }

  .card-desc {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    gap: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .card-footer {
    margin-top: var(--space-3);
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
    transition: gap var(--transition-fast);
  }

  .tutorial-card:hover .read-more {
    gap: 0.5rem;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-8);
    background: var(--color-bg-secondary);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text-secondary);
  }

  .empty-icon {
    color: var(--color-text-muted);
    opacity: 0.5;
    margin-bottom: var(--space-4);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 1.875rem;
    }

    .tutorials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
