---
import { Calendar, User, Tag, ArrowLeft, Clock } from 'lucide-astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map((tutorial) => ({
    params: { slug: tutorial.id },
    props: { tutorial },
  }));
}

const { tutorial } = Astro.props;
const { Content } = await render(tutorial);

// 计算阅读时间（中文字数 / 300 字每分钟）
function calculateReadingTime(content: string): number {
  // 移除代码块和 frontmatter
  const text = content.replace(/```[\s\S]*?```/g, '').replace(/---[\s\S]*?---/g, '');
  // 计算中文字符数（包括标点）
  const chineseChars = (text.match(/[\u4e00-\u9fff]/g) || []).length;
  // 计算英文单词数
  const englishWords = (text.match(/[a-zA-Z]+/g) || []).length;
  // 总字数估算
  const totalChars = chineseChars + englishWords;
  // 阅读时间（向上取整）
  return Math.ceil(totalChars / 300) || 1;
}

const readingTime = calculateReadingTime(tutorial.body);
---

<BaseLayout
  title={tutorial.data.title}
  description={tutorial.data.description}
  image={tutorial.data.heroImage}
>
  <article class="tutorial">
    <header class="header">
      <div class="header-bg">
        <div class="glow"></div>
      </div>
      <div class="breadcrumb">
        <a href="/">首页</a>
        <span class="separator">/</span>
        <a href="/tutorials">教程</a>
        <span class="separator">/</span>
        <span class="current">文章</span>
      </div>
      <h1>{tutorial.data.title}</h1>
      <p class="description">{tutorial.data.description}</p>
      <div class="meta">
        <div class="meta-left">
          <span class="meta-item">
            <Calendar size={16} class="icon" />
            {tutorial.data.pubDate.toLocaleDateString('zh-CN')}
          </span>
          <span class="meta-item">
            <Clock size={16} class="icon" />
            约 {readingTime} 分钟阅读
          </span>
        </div>
        {tutorial.data.tags && tutorial.data.tags.length > 0 && (
          <div class="tags">
            {tutorial.data.tags.map(tag => (
              <span class="tag">
                <Tag size={12} style="display:inline-block;vertical-align:middle;margin-right:4px;" />
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>
    <div class="article-layout">
      <div class="content">
        <Content />
      </div>
      <aside class="article-sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">热门标签</h3>
          <div class="tag-cloud">
            {tutorial.data.tags?.map((tag) => (
              <a href={`/tags/${tag}`} class="tag-pill">
                {tag}
              </a>
            ))}
          </div>
        </div>
        <div class="sidebar-section">
          <h3 class="sidebar-title">资源导航精选</h3>
          <ul class="resource-list">
            <li><a href="/resources/ai-tools" class="resource-link">AI 工具合集</a></li>
            <li><a href="/resources/prompts" class="resource-link">Prompt 模板库</a></li>
            <li><a href="/resources/newsletter" class="resource-link">AI 资讯订阅</a></li>
          </ul>
        </div>
      </aside>
    </div>
    <footer class="article-footer">
      <a href="/tutorials" class="back-link">
        <ArrowLeft size={16} class="arrow" style="display:inline-block;" />
        返回教程列表
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .tutorial {
    max-width: 800px;
    margin: 0 auto;
  }

  .header {
    position: relative;
    margin-bottom: 3rem;
    padding: 2.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .header-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .glow {
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.1) 0%, transparent 70%);
    top: -100px;
    right: -100px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .breadcrumb a:hover {
    color: var(--primary-light);
  }

  .separator {
    color: var(--border);
  }

  .current {
    color: var(--text-dim);
  }

  .header h1 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .header .description {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .meta-left {
    display: flex;
    gap: 1.5rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-dim);
  }

  .icon {
    color: var(--text-dim);
    display: inline-flex;
    align-items: center;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2) 0%, rgba(139, 92, 246, 0.1) 100%);
    color: var(--primary-light);
    padding: 0.35rem 0.875rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid rgba(124, 58, 237, 0.3);
  }

  .article-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: start;
  }

  .content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .content :global(h2) {
    font-size: 1.65rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    font-weight: 700;
    color: var(--text);
  }

  .content :global(h3) {
    font-size: 1.3rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
    color: var(--text);
  }

  .content :global(h4) {
    font-size: 1.1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--text);
  }

  .content :global(p) {
    margin-bottom: 1.25rem;
    color: var(--text-muted);
  }

  .content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .content :global(code) {
    background: var(--bg-card);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: 0.85em;
    font-family: 'Fira Code', 'Consolas', 'Monaco', monospace;
    color: var(--accent);
    border: 1px solid var(--border);
  }

  .content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    position: relative;
  }

  .content :global(pre::before) {
    content: 'Code';
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    font-size: 0.7rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    border: none;
    color: var(--text-muted);
  }

  .content :global(ul), .content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.6rem;
    color: var(--text-muted);
  }

  .content :global(li::marker) {
    color: var(--primary);
  }

  .content :global(a) {
    color: var(--primary-light);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .content :global(a:hover) {
    color: var(--accent);
  }

  .content :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    background: var(--bg-card);
    padding: 1rem 1.25rem;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    background: var(--bg-card);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .content :global(th) {
    background: var(--bg-card-hover);
    padding: 0.875rem 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }

  .content :global(td) {
    padding: 0.875rem 1rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  .content :global(tr:last-child td) {
    border-bottom: none;
  }

  .article-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    color: var(--primary-light);
  }

  .back-link:hover .arrow {
    transform: translateX(-4px);
  }

  .arrow {
    transition: transform 0.3s ease;
    color: var(--text-dim);
  }

  /* 边栏样式 */
  .article-sidebar {
    position: sticky;
    top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .sidebar-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }

  .sidebar-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    background: var(--bg-card-hover);
    border: 1px solid var(--border);
    border-radius: 100px;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .tag-pill:hover {
    color: var(--primary-light);
    border-color: var(--primary-light);
    background: rgba(124, 58, 237, 0.1);
  }

  .resource-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .resource-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .resource-link::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
    transition: background var(--transition-base);
  }

  .resource-link:hover {
    color: var(--primary-light);
    background: rgba(124, 58, 237, 0.05);
  }

  .resource-link:hover::before {
    background: var(--primary-light);
  }

  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
    }
    .article-sidebar {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .header {
      padding: 1.5rem;
    }

    .header h1 {
      font-size: 1.75rem;
    }

    .meta {
      flex-direction: column;
      align-items: flex-start;
    }

    .meta-left {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
