---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const sortedTutorials = tutorials.sort((a, b) => b.data.order - a.data.order);
---

<Layout title="首页" description="摸索AI - AI Agent 教程与实战，OpenClaw、Hermes Agent 使用教程">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-glow"></div>
    </div>
    <div class="hero-content">
      <div class="hero-icon">🔮</div>
      <h1 class="hero-title">
        <span class="text-gradient">摸索AI</span>
      </h1>
      <p class="hero-subtitle">AI Agent 教程与实战</p>
      <p class="hero-desc">
        记录 AI Agent 开发的探索之路，分享 OpenClaw、Hermes Agent 等工具的实战经验。
        从零开始，一步步构建你的智能助手。
      </p>
      <div class="hero-actions">
        <a href="/tutorials" class="btn btn-primary">
          开始学习
          <span class="btn-arrow">→</span>
        </a>
        <a href="/about" class="btn btn-secondary">
          了解更多
        </a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="stat-item">
      <div class="stat-value">{sortedTutorials.length}</div>
      <div class="stat-label">教程</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <div class="stat-value">100%</div>
      <div class="stat-label">免费</div>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <div class="stat-value">实战</div>
      <div class="stat-label">导向</div>
    </div>
  </section>

  <!-- Tutorials Section -->
  <section class="tutorials-section">
    <div class="section-header">
      <h2 class="section-title">最新教程</h2>
      <a href="/tutorials" class="view-all">
        查看全部
        <span class="arrow">→</span>
      </a>
    </div>
    
    {sortedTutorials.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">📚</div>
        <p>还没有教程，敬请期待...</p>
      </div>
    ) : (
      <div class="tutorial-grid">
        {sortedTutorials.slice(0, 6).map((tutorial) => (
          <article class="tutorial-card">
            <div class="card-glow"></div>
            <div class="card-content">
              <div class="card-tags">
                {tutorial.data.tags.slice(0, 3).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h3 class="card-title">
                <a href={`/tutorials/${tutorial.id}`}>{tutorial.data.title}</a>
              </h3>
              <p class="card-desc">{tutorial.data.description}</p>
              <div class="card-meta">
                <span class="card-date">
                  <span class="icon">📅</span>
                  {tutorial.data.pubDate.toLocaleDateString('zh-CN')}
                </span>
                <span class="card-author">
                  <span class="icon">✍️</span>
                  {tutorial.data.author}
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
    
    {sortedTutorials.length > 6 && (
      <div class="section-footer">
        <a href="/tutorials" class="btn btn-outline">
          查看全部教程
          <span class="btn-arrow">→</span>
        </a>
      </div>
    )}
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    text-align: center;
    padding: 5rem 0 4rem;
    margin-bottom: 3rem;
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  
  .hero-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.15) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: pulse 4s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
  }
  
  .hero-content {
    position: relative;
    z-index: 1;
  }
  
  .hero-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
    animation: float 3s ease-in-out infinite;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  
  .hero-subtitle {
    font-size: 1.5rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-weight: 500;
  }
  
  .hero-desc {
    max-width: 600px;
    margin: 0 auto 2rem;
    color: var(--text-dim);
    font-size: 1.1rem;
    line-height: 1.7;
  }
  
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    box-shadow: var(--shadow-md), 0 0 20px rgba(124, 58, 237, 0.4);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg), 0 0 30px rgba(124, 58, 237, 0.5);
    color: white;
  }
  
  .btn-secondary {
    background: var(--bg-card);
    color: var(--text);
    border: 1px solid var(--border);
  }
  
  .btn-secondary:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-light);
    color: var(--text);
  }
  
  .btn-outline {
    background: transparent;
    color: var(--primary-light);
    border: 2px solid var(--primary);
  }
  
  .btn-outline:hover {
    background: var(--primary);
    color: white;
  }
  
  .btn-arrow {
    transition: transform 0.3s ease;
  }
  
  .btn:hover .btn-arrow {
    transform: translateX(4px);
  }
  
  /* Stats */
  .stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    padding: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 4rem;
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, var(--primary-light) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .stat-label {
    color: var(--text-dim);
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }
  
  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }
  
  /* Section */
  .tutorials-section {
    margin-top: 2rem;
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border);
  }
  
  .section-title {
    font-size: 1.8rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .section-title::before {
    content: '📖';
    font-size: 1.5rem;
  }
  
  .view-all {
    color: var(--primary-light);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.3s ease;
  }
  
  .view-all:hover {
    gap: 0.75rem;
  }
  
  /* Tutorial Grid */
  .tutorial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }
  
  .tutorial-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
  }
  
  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(124, 58, 237, 0.1) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  
  .tutorial-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: var(--shadow-lg), 0 0 30px rgba(124, 58, 237, 0.2);
  }
  
  .tutorial-card:hover .card-glow {
    opacity: 1;
  }
  
  .card-content {
    position: relative;
    z-index: 1;
    padding: 1.5rem;
  }
  
  .card-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  
  .tag {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.2) 0%, rgba(139, 92, 246, 0.1) 100%);
    color: var(--primary-light);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid rgba(124, 58, 237, 0.3);
  }
  
  .card-title {
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.4;
  }
  
  .card-title a {
    color: var(--text);
    transition: color 0.2s ease;
  }
  
  .card-title a:hover {
    color: var(--primary-light);
  }
  
  .card-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .card-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  
  .card-date, .card-author {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  
  .icon {
    font-size: 0.9rem;
  }
  
  .section-footer {
    text-align: center;
    margin-top: 3rem;
  }
  
  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }
  
  .empty-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }
  
  .empty-state p {
    color: var(--text-muted);
    font-size: 1.1rem;
  }
  
  /* Mobile */
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0 2rem;
    }
    
    .hero-title {
      font-size: 2.25rem;
    }
    
    .hero-subtitle {
      font-size: 1.25rem;
    }
    
    .hero-desc {
      font-size: 1rem;
    }
    
    .stats {
      flex-direction: column;
      gap: 1.5rem;
    }
    
    .stat-divider {
      width: 40px;
      height: 1px;
    }
    
    .tutorial-grid {
      grid-template-columns: 1fr;
    }
    
    .section-header {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }
  }
</style>
