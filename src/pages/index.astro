---
import { Newspaper, Star, BookOpen, Grid, ArrowRight, Calendar, Bot, Code } from 'lucide-astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取资讯
const allNews = await getCollection('news', ({ data }) => !data.draft);
const sortedNews = allNews.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestNews = sortedNews.slice(0, 5);

// 获取教程
const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);
const sortedTutorials = allTutorials.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredTutorials = sortedTutorials.slice(0, 3);

// 获取评测
const allReviews = await getCollection('reviews', ({ data }) => !data.draft);
const sortedReviews = allReviews.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredReviews = sortedReviews.slice(0, 3);

// 获取资源
const allResources = await getCollection('resources', ({ data }) => !data.draft);
const featuredResources = allResources.filter((r) => r.data.featured).slice(0, 4);

// 获取开源项目
const allOpensource = await getCollection('opensource', ({ data }) => !data.draft);
const sortedOpensource = allOpensource.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredOpensource = sortedOpensource.slice(0, 3);
---

<BaseLayout title="MosuoAI" description="AI Agent 开发者的深度指南">
  <div class="homepage">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg">
        <div class="hero-glow"></div>
      </div>
      <div class="hero-content">
        <h1 class="hero-title">
          <span class="text-gradient">MosuoAI</span>
        </h1>
        <p class="hero-subtitle">AI Agent 开发者的深度指南</p>
        <p class="hero-desc">
          探索 AI Agent 开发的无限可能，分享 OpenClaw、Hermes Agent 等工具的实战经验。
          从入门到精通，陪你走好每一步。
        </p>
      </div>
    </section>

    <!-- 资讯快报 -->
    <section class="content-section">
      <div class="section-header">
        <div class="section-title-wrapper">
          <Newspaper size={24} class="section-icon" />
          <h2 class="section-title">资讯快报</h2>
        </div>
        <a href="/news" class="section-more">
          查看更多 <ArrowRight size={16} />
        </a>
      </div>

      {latestNews.length === 0 ? (
        <div class="empty-state">
          <Newspaper size={48} class="empty-icon" />
          <p>暂无资讯，敬请期待...</p>
        </div>
      ) : (
        <div class="news-list">
          {latestNews.map((news) => (
            <article class="news-item">
              <a href={`/news/${news.id}`} class="news-link"></a>
              <div class="news-content">
                <h3 class="news-title">{news.data.title}</h3>
                <p class="news-excerpt">{news.data.description}</p>
                <div class="news-meta">
                  <span class="news-date">
                    <Calendar size={14} />
                    {news.data.pubDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
                  </span>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- 精选教程 -->
    <section class="content-section">
      <div class="section-header">
        <div class="section-title-wrapper">
          <BookOpen size={24} class="section-icon" />
          <h2 class="section-title">精选教程</h2>
        </div>
        <a href="/tutorials" class="section-more">
          查看更多 <ArrowRight size={16} />
        </a>
      </div>

      {featuredTutorials.length === 0 ? (
        <div class="empty-state">
          <BookOpen size={48} class="empty-icon" />
          <p>暂无教程，敬请期待...</p>
        </div>
      ) : (
        <div class="card-grid">
          {featuredTutorials.map((tutorial) => (
            <article class="card tutorial-card">
              <a href={`/tutorials/${tutorial.id}`} class="card-link"></a>
              <div class="card-glow"></div>
              <div class="card-content">
                <div class="card-header">
                  <span class="difficulty-badge difficulty-{tutorial.data.difficulty}">
                    {tutorial.data.difficulty === 'beginner' && '入门'}
                    {tutorial.data.difficulty === 'intermediate' && '进阶'}
                    {tutorial.data.difficulty === 'advanced' && '高级'}
                  </span>
                </div>
                <h3 class="card-title">{tutorial.data.title}</h3>
                <p class="card-desc">{tutorial.data.description}</p>
                {tutorial.data.tags && tutorial.data.tags.length > 0 && (
                  <div class="card-tags">
                    {tutorial.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- 精选评测 -->
    <section class="content-section">
      <div class="section-header">
        <div class="section-title-wrapper">
          <Star size={24} class="section-icon" />
          <h2 class="section-title">工具评测</h2>
        </div>
        <a href="/reviews" class="section-more">
          查看更多 <ArrowRight size={16} />
        </a>
      </div>

      {featuredReviews.length === 0 ? (
        <div class="empty-state">
          <Star size={48} class="empty-icon" />
          <p>暂无评测，敬请期待...</p>
        </div>
      ) : (
        <div class="card-grid">
          {featuredReviews.map((review) => (
            <article class="card review-card">
              <a href={`/reviews/${review.id}`} class="card-link"></a>
              <div class="card-glow"></div>
              <div class="card-content">
                <div class="card-header">
                  <div class="rating">
                    {'★'.repeat(Math.floor(review.data.rating))}
                    <span class="rating-score">{review.data.rating}</span>
                  </div>
                </div>
                <h3 class="card-title">{review.data.title}</h3>
                <p class="card-desc">{review.data.description}</p>
                {review.data.tags && review.data.tags.length > 0 && (
                  <div class="card-tags">
                    {review.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- 开源精选 -->
    <section class="content-section">
      <div class="section-header">
        <div class="section-title-wrapper">
          <Code size={24} class="section-icon" />
          <h2 class="section-title">开源精选</h2>
        </div>
        <a href="/opensource" class="section-more">
          查看更多 <ArrowRight size={16} />
        </a>
      </div>

      {featuredOpensource.length === 0 ? (
        <div class="empty-state">
          <Code size={48} class="empty-icon" />
          <p>暂无开源内容，敬请期待...</p>
        </div>
      ) : (
        <div class="card-grid">
          {featuredOpensource.map((project) => (
            <article class="card opensource-card">
              <a href={`/opensource/${project.id}`} class="card-link"></a>
              <div class="card-glow"></div>
              <div class="card-content">
                <div class="card-header">
                  {project.data.language && (
                    <span class="language-badge">
                      <span class="language-dot" style={`background: ${getLanguageColor(project.data.language)}`}></span>
                      {project.data.language}
                    </span>
                  )}
                </div>
                <h3 class="card-title">{project.data.title}</h3>
                <p class="card-desc">{project.data.description}</p>
                {project.data.tags && project.data.tags.length > 0 && (
                  <div class="card-tags">
                    {project.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">#{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      )}
    </section>

    <!-- 资源导航 -->
    <section class="content-section">
      <div class="section-header">
        <div class="section-title-wrapper">
          <Grid size={24} class="section-icon" />
          <h2 class="section-title">资源导航</h2>
        </div>
        <a href="/resources" class="section-more">
          查看更多 <ArrowRight size={16} />
        </a>
      </div>

      {featuredResources.length === 0 ? (
        <div class="empty-state">
          <Grid size={48} class="empty-icon" />
          <p>暂无资源，敬请期待...</p>
        </div>
      ) : (
        <div class="resource-grid">
          {featuredResources.map((resource) => (
            <a href={resource.data.url} target="_blank" rel="noopener noreferrer" class="resource-item">
              <div class="resource-content">
                <h3 class="resource-title">{resource.data.title}</h3>
                <p class="resource-desc">{resource.data.description}</p>
              </div>
              <ArrowRight size={16} class="resource-icon" />
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Sidebar -->
    <aside class="sidebar">
      <!-- Author Card -->
      <div class="sidebar-card author-card">
        <Bot size={64} class="author-avatar" />
        <h3 class="author-name">老李</h3>
        <p class="author-bio">
          AI Agent 开发者，热衷于探索 AI 技术的实际应用。
          在这里分享实战经验和踩坑记录。
        </p>
        <div class="author-social">
          <a href="/about" class="social-link">关于我</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  function getLanguageColor(language) {
    const colors = {
      TypeScript: '#3178c6',
      JavaScript: '#f7df1e',
      Python: '#3776ab',
      Go: '#00ADD8',
      Rust: '#dea584',
      Java: '#b07219',
      CSharp: '#178600',
      Ruby: '#701516',
      PHP: '#4F5D95',
      Swift: '#ffac45',
      Kotlin: '#A97BFF',
    };
    return colors[language] || '#777';
  }
</script>

<style>
  .homepage { position: relative; }

  .hero {
    position: relative;
    text-align: center;
    padding: 4rem 0 3rem;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 212, 224, 0.12) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
  }

  .hero-content { position: relative; z-index: 1; }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .hero-desc {
    max-width: 600px;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .content-section {
    margin-bottom: 3rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .section-title-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-icon {
    color: var(--color-primary);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .section-more {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.9rem;
    transition: gap var(--transition-fast);
  }

  .section-more:hover {
    gap: 0.5rem;
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .news-item {
    position: relative;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    transition: all var(--transition-base);
  }

  .news-item:hover {
    border-color: var(--color-primary);
    transform: translateX(8px);
  }

  .news-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .news-content {
    position: relative;
    z-index: 2;
  }

  .news-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }

  .news-excerpt {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .card {
    position: relative;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 212, 224, 0.12);
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(0, 212, 224, 0.08) 0%, transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .card:hover .card-glow {
    opacity: 1;
  }

  .card-content {
    position: relative;
    z-index: 2;
  }

  .card-header {
    margin-bottom: 0.75rem;
  }

  .difficulty-badge {
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .difficulty-beginner {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .difficulty-intermediate {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  .difficulty-advanced {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .language-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.5rem;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: var(--color-text-secondary);
  }

  .language-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }

  .card-desc {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    background: rgba(0, 212, 224, 0.1);
    color: var(--color-primary);
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid rgba(0, 212, 224, 0.2);
  }

  .rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: #fbbf24;
    font-size: 0.9rem;
  }

  .rating-score {
    font-weight: 600;
    margin-left: 0.25rem;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .resource-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem;
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  .resource-item:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .resource-content {
    flex: 1;
    min-width: 0;
  }

  .resource-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .resource-desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .resource-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .sidebar {
    position: fixed;
    top: 100px;
    right: 20px;
    width: 280px;
  }

  .sidebar-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .author-card {
    text-align: center;
  }

  .author-avatar {
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .author-name {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .author-bio {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .author-social {
    display: flex;
    justify-content: center;
  }

  .social-link {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    background: var(--color-primary);
    color: white;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-icon {
    color: var(--color-text-muted);
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  @media (max-width: 1024px) {
    .sidebar {
      position: static;
      width: 100%;
      margin-top: 2rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2.5rem 0 2rem;
    }

    .hero-title {
      font-size: 2.25rem;
    }

    .hero-subtitle {
      font-size: 1.15rem;
    }

    .hero-desc {
      font-size: 0.95rem;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
