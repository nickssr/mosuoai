---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const tutorials = await getCollection('tutorials');
const sortedTutorials = tutorials.sort((a, b) => b.data.order - a.data.order);
---

<Layout title="首页" description="摸索AI - AI Agent 教程与实战，OpenClaw、Hermes Agent 使用教程">
  <section class="hero">
    <h1>摸索AI</h1>
    <p class="subtitle">AI Agent 教程与实战</p>
    <p class="description">
      记录 AI Agent 开发的探索之路，分享 OpenClaw、Hermes Agent 等工具的实战经验。
    </p>
  </section>

  <section class="tutorials-section">
    <h2>最新教程</h2>
    <div class="tutorial-grid">
      {sortedTutorials.slice(0, 6).map((tutorial) => (
        <article class="tutorial-card">
          <h3>
            <a href={`/tutorials/${tutorial.id}`}>{tutorial.data.title}</a>
          </h3>
          <p class="description">{tutorial.data.description}</p>
          <div class="meta">
            <span class="date">{tutorial.data.pubDate.toLocaleDateString('zh-CN')}</span>
            {tutorial.data.tags.length > 0 && (
              <div class="tags">
                {tutorial.data.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
    {sortedTutorials.length > 6 && (
      <a href="/tutorials" class="view-all">查看全部教程 →</a>
    )}
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    margin-bottom: 3rem;
  }
  
  .hero h1 {
    font-size: 3rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--accent), #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .subtitle {
    font-size: 1.5rem;
    color: #888;
    margin-bottom: 1rem;
  }
  
  .description {
    max-width: 600px;
    margin: 0 auto;
    color: #aaa;
    font-size: 1.1rem;
  }
  
  .tutorials-section {
    margin-top: 2rem;
  }
  
  .tutorials-section h2 {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--accent);
    display: inline-block;
  }
  
  .tutorial-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
  }
  
  .tutorial-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.2s, border-color 0.2s;
  }
  
  .tutorial-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }
  
  .tutorial-card h3 {
    margin-bottom: 0.75rem;
  }
  
  .tutorial-card h3 a {
    color: var(--text);
  }
  
  .tutorial-card h3 a:hover {
    color: var(--accent);
  }
  
  .tutorial-card .description {
    color: #aaa;
    font-size: 0.95rem;
    margin-bottom: 1rem;
    text-align: left;
  }
  
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: #888;
  }
  
  .tags {
    display: flex;
    gap: 0.5rem;
  }
  
  .tag {
    background: var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
  }
  
  .view-all {
    display: inline-block;
    margin-top: 2rem;
    font-size: 1.1rem;
    font-weight: 500;
  }
  
  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }
    
    .tutorial-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
