---
import { Calendar } from 'lucide-astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PopularArticles from '../components/PopularArticles.astro';
import { getCollection } from 'astro:content';

// 获取所有文章
const allNews = await getCollection('news', ({ data }) => !data.draft);
const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);
const allReviews = await getCollection('reviews', ({ data }) => !data.draft);
const allOpensource = await getCollection('opensource', ({ data }) => !data.draft);

// 统一合并为文章列表
interface UnifiedArticle {
  type: 'news' | 'tutorials' | 'reviews' | 'opensource';
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags?: string[];
  categoryLabel: string;
  categoryColor: string;
}

const articles: UnifiedArticle[] = [
  ...allNews.map((n) => ({
    type: 'news' as const,
    id: n.id,
    title: n.data.title,
    description: n.data.description,
    pubDate: n.data.pubDate,
    heroImage: n.data.heroImage,
    tags: n.data.tags,
    categoryLabel: '资讯',
    categoryColor: '#3b82f6',
  })),
  ...allTutorials.map((t) => ({
    type: 'tutorials' as const,
    id: t.id,
    title: t.data.title,
    description: t.data.description,
    pubDate: t.data.pubDate,
    heroImage: t.data.heroImage,
    tags: t.data.tags,
    categoryLabel: '教程',
    categoryColor: '#10b981',
  })),
  ...allReviews.map((r) => ({
    type: 'reviews' as const,
    id: r.id,
    title: r.data.title,
    description: r.data.description,
    pubDate: r.data.pubDate,
    heroImage: r.data.heroImage,
    tags: r.data.tags,
    categoryLabel: '评测',
    categoryColor: '#f59e0b',
  })),
  ...allOpensource.map((o) => ({
    type: 'opensource' as const,
    id: o.id,
    title: o.data.title,
    description: o.data.description,
    pubDate: o.data.pubDate,
    heroImage: o.data.heroImage,
    tags: o.data.tags,
    categoryLabel: '开源',
    categoryColor: '#8b5cf6',
  })),
].sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const defaultThumb = '/og-default.svg';
---

<BaseLayout title="MosuoAI" description="探索 AI 技术，分享知识洞见">
  <PageHero
    title="Mosuo AI"
    description="AI资讯、教程、学习、评测一站式内容平台"
    isHome
  />

  <div class="page-layout">
    <main class="main-content">
      <div class="article-list">
        {articles.map((article) => (
          <article class="article-card">
            <a href={`/${article.type}/${article.id}`} class="article-card-link"></a>
            <div class="article-card-thumb">
              <img
                src={article.heroImage || defaultThumb}
                alt={article.title}
                loading="lazy"
              />
            </div>
            <div class="article-card-body">
              <div class="article-card-meta">
                <span class="category-badge" style={{ 'background': `${article.categoryColor}20`, 'color': article.categoryColor }}>
                  {article.categoryLabel}
                </span>
                <span class="date-text">
                  <Calendar size={12} />
                  {article.pubDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
                </span>
              </div>
              <h3 class="article-card-title">{article.title}</h3>
              <p class="article-card-desc">{article.description}</p>
            </div>
          </article>
        ))}
      </div>
    </main>

    <aside class="sidebar">
      <PopularArticles />
      <div class="sidebar-section">
        <h3 class="sidebar-title">热门标签</h3>
        <div class="tag-cloud">
          {Array.from(new Set(articles.flatMap((a) => a.tags ?? [])))
            .slice(0, 20)
            .map((tag) => (
              <a href={`/tags/${tag}`} class="tag-pill">
                {tag}
              </a>
            ))}
        </div>
      </div>


    </aside>
  </div>
</BaseLayout>
