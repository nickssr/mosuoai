---
import { ArrowRight, Calendar, Star, BookOpen, Newspaper } from 'lucide-astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取所有文章
const allNews = await getCollection('news', ({ data }) => !data.draft);
const allTutorials = await getCollection('tutorials', ({ data }) => !data.draft);
const allReviews = await getCollection('reviews', ({ data }) => !data.draft);

// 统一合并为文章列表
interface UnifiedArticle {
  type: 'news' | 'tutorials' | 'reviews';
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags?: string[];
  categoryLabel: string;
  categoryColor: string;
}

const articles: UnifiedArticle[] = [
  ...allNews.map((n) => ({
    type: 'news' as const,
    id: n.id,
    title: n.data.title,
    description: n.data.description,
    pubDate: n.data.pubDate,
    heroImage: n.data.heroImage,
    tags: n.data.tags,
    categoryLabel: '资讯',
    categoryColor: '#3b82f6',
  })),
  ...allTutorials.map((t) => ({
    type: 'tutorials' as const,
    id: t.id,
    title: t.data.title,
    description: t.data.description,
    pubDate: t.data.pubDate,
    heroImage: t.data.heroImage,
    tags: t.data.tags,
    categoryLabel: '教程',
    categoryColor: '#10b981',
  })),
  ...allReviews.map((r) => ({
    type: 'reviews' as const,
    id: r.id,
    title: r.data.title,
    description: r.data.description,
    pubDate: r.data.pubDate,
    heroImage: r.data.heroImage,
    tags: r.data.tags,
    categoryLabel: '评测',
    categoryColor: '#f59e0b',
  })),
].sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const defaultThumb = '/og-default.svg';
---

<BaseLayout title="MosuoAI" description="AI Agent 开发者的深度指南">
  <!-- Hero 区 -->
  <section class="hero-section">
    <div class="hero-bg">
      <div class="hero-glow"></div>
    </div>
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="text-gradient">Mosuo AI</span>
      </h1>
      <p class="hero-subtitle">探索 · 构建 · 部署</p>
      <p class="hero-desc">
        AI Agent 资讯、教程、学习、评测一站式内容平台
      </p>
    </div>
  </section>

  <div class="home-layout">
    <!-- 统一文章列表 -->
    <main class="main-content">
      <div class="article-list">
        {articles.map((article) => (
          <article class="article-card">
            <a href={`/${article.type}/${article.id}`} class="article-card-link"></a>
            <div class="article-card-thumb">
              <img
                src={article.heroImage || defaultThumb}
                alt={article.title}
                loading="lazy"
              />
            </div>
            <div class="article-card-body">
              <div class="article-card-meta">
                <span class="category-badge" style={{ 'background': `${article.categoryColor}20`, 'color': article.categoryColor }}>
                  {article.categoryLabel}
                </span>
                <span class="date-text">
                  <Calendar size={12} />
                  {article.pubDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
                </span>
              </div>
              <h3 class="article-card-title">{article.title}</h3>
              <p class="article-card-desc">{article.description}</p>
            </div>
          </article>
        ))}
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  /* Hero 区 */
  .hero-section {
    position: relative;
    text-align: center;
    width: 100vw;
    margin-left: calc((100vw - 100%) / -2);
    margin-top: calc(var(--space-8) * -1);
    margin-bottom: 3rem;
    padding: 5rem 2rem 4rem;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(0, 212, 224, 0.08) 0%, rgba(0, 212, 224, 0.02) 50%, transparent 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 212, 224, 0.12) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.1); }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .hero-desc {
    max-width: 600px;
    margin: 0 auto;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* 主布局 */
  .home-layout {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem 2rem;
  }

  .main-content {
    min-width: 0;
  }

  /* 统一文章列表 */
  .article-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* 文章卡片 */
  .article-card {
    position: relative;
    display: flex;
    gap: 1.25rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .article-card:hover {
    border-color: var(--color-primary);
    background: rgba(0, 212, 224, 0.02);
    transform: translateX(4px);
  }

  .article-card-link {
    position: absolute;
    inset: 0;
    z-index: 10;
  }

  /* 缩略图 */
  .article-card-thumb {
    flex-shrink: 0;
    width: 160px;
    height: 110px;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg-tertiary);
  }

  .article-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .article-card:hover .article-card-thumb img {
    transform: scale(1.05);
  }

  /* 卡片内容 */
  .article-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .date-text {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-text-muted);
  }

  .article-card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card:hover .article-card-title {
    color: var(--color-primary);
  }

  .article-card-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .hero-section {
      padding: 3rem 1rem 2rem;
    }

    .hero-title {
      font-size: 2.25rem;
    }

    .hero-subtitle {
      font-size: 1.15rem;
    }

    .hero-desc {
      font-size: 0.95rem;
    }

    .home-layout {
      padding: 0 1rem 1rem;
    }

    .article-card {
      flex-direction: column;
      padding: 1rem;
    }

    .article-card-thumb {
      width: 100%;
      height: 140px;
    }

    .article-card-title {
      font-size: 1rem;
    }

    .article-card-desc {
      font-size: 0.85rem;
      -webkit-line-clamp: 3;
    }
  }
</style>
