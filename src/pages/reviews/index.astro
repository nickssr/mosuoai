---
import { Star, ThumbsUp, ThumbsDown, ArrowRight } from 'lucide-astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews', ({ data }) => !data.draft);
const sortedReviews = allReviews.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="评测" description="AI 工具深度评测 - Cursor AI、Claude Code 等开发者工具实战分析">
  <section class="page-header">
    <h1>工具评测</h1>
    <p class="subtitle">深度评测 AI 开发者工具，帮你选择最适合的利器</p>
  </section>

  {sortedReviews.length === 0 ? (
    <div class="empty-state">
      <Star size={64} class="empty-icon" />
      <h2>评测正在筹备中</h2>
      <p>精彩内容即将上线，敬请期待...</p>
    </div>
  ) : (
    <div class="reviews-grid">
      {sortedReviews.map((review) => (
        <article class="review-card" style={`--rating: ${review.data.rating}`}>
          <a href={`/reviews/${review.id}`} class="card-link"></a>
          <div class="card-glow"></div>
          <div class="card-content">
            {review.data.heroImage && (
              <div class="card-hero">
                <img src={review.data.heroImage} alt={review.data.title} loading="lazy" />
              </div>
            )}
            <div class="card-header">
              <div class="rating">
                {[...Array(5)].map((_, i) => (
                  <Star
                    size={16}
                    class={i < review.data.rating ? 'filled' : 'empty'}
                    fill={i < review.data.rating ? 'currentColor' : 'none'}
                  />
                ))}
              </div>
              <time datetime={review.data.pubDate.toISOString()}>
                {review.data.pubDate.toLocaleDateString('zh-CN', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric'
                })}
              </time>
            </div>

            <h2>{review.data.title}</h2>
            <p class="description">{review.data.description}</p>

            {review.data.pros?.length > 0 && (
              <div class="pros">
                <div class="pros-label">
                  <ThumbsUp size={14} />
                  优点
                </div>
                <ul class="pros-list">
                  {review.data.pros.slice(0, 3).map((pro) => (
                    <li>{pro}</li>
                  ))}
                </ul>
              </div>
            )}

            {review.data.cons?.length > 0 && (
              <div class="cons">
                <div class="cons-label">
                  <ThumbsDown size={14} />
                  不足
                </div>
                <ul class="cons-list">
                  {review.data.cons.slice(0, 2).map((con) => (
                    <li>{con}</li>
                  ))}
                </ul>
              </div>
            )}

            <div class="card-footer">
              {review.data.verdict && (
                <p class="verdict">{review.data.verdict}</p>
              )}
              <span class="read-more">
                阅读全文 <ArrowRight size={14} />
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    padding: 3rem 0;
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
  }

  .review-card {
    position: relative;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .card-hero {
    width: 100%;
    height: 160px;
    margin: calc(-1 * var(--space-5)) calc(-1 * var(--space-5)) var(--space-4);
    overflow: hidden;
  }

  .card-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .review-card:hover .card-hero img {
    transform: scale(1.05);
  }

  .review-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 212, 224, 0.12);
  }

  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, rgba(0, 212, 224, 0.08) 0%, transparent 50%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .review-card:hover .card-glow {
    opacity: 1;
  }

  .card-content {
    position: relative;
    z-index: 2;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .rating {
    display: flex;
    gap: 2px;
    color: #fbbf24;
  }

  .rating .empty {
    color: var(--color-text-muted);
    opacity: 0.3;
  }

  .card-header time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    line-height: 1.4;
    color: var(--color-text-primary);
  }

  .description {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pros, .cons {
    margin-bottom: 0.75rem;
  }

  .pros-label, .cons-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .pros-label {
    color: #10b981;
  }

  .cons-label {
    color: #f59e0b;
  }

  .pros-list, .cons-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pros-list li, .cons-list li {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    padding: 0.25rem 0;
    padding-left: 1rem;
    position: relative;
  }

  .pros-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #10b981;
    font-weight: 600;
  }

  .cons-list li::before {
    content: '×';
    position: absolute;
    left: 0;
    color: #f59e0b;
    font-weight: 600;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    margin-top: 1rem;
  }

  .verdict {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-style: italic;
    max-width: 70%;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.85rem;
    white-space: nowrap;
    transition: gap var(--transition-fast);
  }

  .review-card:hover .read-more {
    gap: 0.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-icon {
    color: var(--color-text-muted);
    opacity: 0.5;
    margin-bottom: 1rem;
  }

  .empty-state h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-primary);
  }

  .empty-state p {
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
