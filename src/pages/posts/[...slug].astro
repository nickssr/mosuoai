---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { slug } from 'github-slugger';

interface Props {
  params: {
    slug: string;
  };
}

const allPosts = await getCollection('posts');

function getPostFromSlug(slugStr: string) {
  return allPosts.find((post) => post.slug === slugStr);
}

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { slug: slugParam } = Astro.params;
const post = getPostFromSlug(slugParam);

if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);

// 计算阅读时长（假设每分钟 200 字）
const textContent = post.body.replace(/[#*_`~\[\]()]/g, '').trim();
const wordCount = textContent.length;
const readingTime = Math.ceil(wordCount / 200);

// 提取标题用于目录
const headings: Array<{ depth: number; slug: string; text: string }> = [];
const headingRegex = /^(#{2,3})\s+(.+)$/gm;
let match;
while ((match = headingRegex.exec(post.body)) !== null) {
  const depth = match[1].length;
  const text = match[2].trim();
  headings.push({
    depth,
    slug: slug(text),
    text,
  });
}

// 获取上一篇和下一篇文章
const sortedPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

// 难度徽章配置
const difficultyConfig = {
  beginner: { label: '入门', color: 'var(--color-success)' },
  intermediate: { label: '进阶', color: 'var(--color-warning)' },
  advanced: { label: '高级', color: 'var(--color-error)' },
};

const difficulty = difficultyConfig[post.data.difficulty];

// 分类中文名
const categoryNames: Record<string, string> = {
  tutorial: '教程',
  review: '评测',
  'case-study': '案例',
  news: '资讯',
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: post.data.updatedDate?.toISOString(),
  }}
>
  <article class="post">
    <!-- 文章头部 -->
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>

      <div class="post-meta">
        <span class="meta-item">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        </span>
        <span class="meta-divider">•</span>
        <span class="meta-item">{readingTime} 分钟阅读</span>
        <span class="meta-divider">•</span>
        <span class="meta-category" style={`color: ${difficulty.color};`}>
          {categoryNames[post.data.category]}
        </span>
        <span class="meta-divider">•</span>
        <span class="difficulty-badge" style={`background: ${difficulty.color};`}>
          {difficulty.label}
        </span>
      </div>

      {post.data.heroImage && (
        <div class="post-hero">
          <img src={post.data.heroImage} alt={post.data.title} />
        </div>
      )}

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-tags">
          {post.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <!-- 内容区域：正文 + 目录 -->
    <div class="post-content-wrapper">
      <!-- 文章正文 -->
      <div class="post-body">
        <Content />
      </div>

      <!-- 目录（桌面端） -->
      <aside class="post-sidebar">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <!-- 文章尾部 -->
    <footer class="post-footer">
      <!-- 标签列表 -->
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="footer-tags">
          <span class="footer-label">标签：</span>
          {post.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      )}

      <!-- 上一篇/下一篇导航 -->
      {(prevPost || nextPost) && (
        <nav class="post-nav">
          {prevPost && (
            <a href={`/posts/${prevPost.slug}`} class="nav-item nav-prev">
              <span class="nav-label">上一篇</span>
              <span class="nav-title">{prevPost.data.title}</span>
            </a>
          )}
          {nextPost && (
            <a href={`/posts/${nextPost.slug}`} class="nav-item nav-next">
              <span class="nav-label">下一篇</span>
              <span class="nav-title">{nextPost.data.title}</span>
            </a>
          )}
        </nav>
      )}

      <!-- 评论区预留 -->
      <div id="comments" class="comments-placeholder">
        <!-- 评论区将在此处加载 -->
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  /* 文章头部 */
  .post-header {
    margin-bottom: var(--space-10);
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-5);
    background: linear-gradient(135deg, var(--color-text-primary) 0%, var(--color-text-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .meta-divider {
    color: var(--color-text-muted);
  }

  .difficulty-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
    color: #fff;
  }

  .post-hero {
    margin: var(--space-8) 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .post-hero img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .tag {
    font-size: 0.875rem;
    color: var(--color-primary);
    background: rgba(0, 212, 224, 0.1);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
  }

  .tag:hover {
    background: rgba(0, 212, 224, 0.2);
    color: var(--color-primary-dark);
  }

  /* 内容区域布局 */
  .post-content-wrapper {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: start;
  }

  .post-body {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  /* 文章正文排版 */
  .post-body :global(h2) {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: var(--space-12) 0 var(--space-5);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .post-body :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: var(--space-10) 0 var(--space-4);
  }

  .post-body :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: var(--space-8) 0 var(--space-3);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-5);
  }

  .post-body :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .post-body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .post-body :global(a:hover) {
    color: var(--color-primary-dark);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .post-body :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-body :global(li > ul),
  .post-body :global(li > ol) {
    margin-top: var(--space-2);
    margin-bottom: 0;
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: var(--space-4) var(--space-6);
    margin: var(--space-6) 0;
    background: var(--color-bg-secondary);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
  }

  .post-body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-10) 0;
  }

  /* 表格 */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
    font-size: 0.9375rem;
  }

  .post-body :global(th) {
    background: var(--color-bg-tertiary);
    font-weight: 600;
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
  }

  .post-body :global(td) {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
  }

  .post-body :global(tr:nth-child(even)) {
    background: var(--color-bg-secondary);
  }

  /* 图片 */
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: var(--space-6) 0;
  }

  /* 文章尾部 */
  .post-footer {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .footer-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  .footer-label {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  /* 上下篇导航 */
  .post-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .nav-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .nav-item:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-tertiary);
  }

  .nav-label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    font-weight: 500;
  }

  /* 评论区预留 */
  .comments-placeholder {
    padding: var(--space-8);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    border: 1px dashed var(--color-border);
  }

  /* 响应式 */
  @media (max-width: 1024px) {
    .post-content-wrapper {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.75rem;
    }

    .post-body {
      font-size: 1rem;
    }

    .post-body :global(h2) {
      font-size: 1.5rem;
    }

    .post-body :global(h3) {
      font-size: 1.25rem;
    }
  }
</style>
