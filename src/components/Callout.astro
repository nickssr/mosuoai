---
import { Icon } from 'lucide-astro';
import { Info, TriangleAlert, CircleCheck, CircleX } from 'lucide-astro/icons';

interface Props {
  type?: 'info' | 'warning' | 'success' | 'error';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const config = {
  info: {
    icon: Info,
    borderColor: 'var(--color-info)',
    bgColor: 'rgba(59, 130, 246, 0.1)',
    titleColor: 'var(--color-info)',
  },
  warning: {
    icon: TriangleAlert,
    borderColor: 'var(--color-warning)',
    bgColor: 'rgba(245, 158, 11, 0.1)',
    titleColor: 'var(--color-warning)',
  },
  success: {
    icon: CircleCheck,
    borderColor: 'var(--color-success)',
    bgColor: 'rgba(16, 185, 129, 0.1)',
    titleColor: 'var(--color-success)',
  },
  error: {
    icon: CircleX,
    borderColor: 'var(--color-error)',
    bgColor: 'rgba(239, 68, 68, 0.1)',
    titleColor: 'var(--color-error)',
  },
};

const currentConfig = config[type];
---

<div class="callout" style={`border-left-color: ${currentConfig.borderColor}; background: ${currentConfig.bgColor};`}>
  {title && (
    <div class="callout-title" style={`color: ${currentConfig.titleColor};`}>
      <Icon name={currentConfig.icon} size={18} class="callout-icon" />
      <span>{title}</span>
    </div>
  )}
  <div class="callout-content">
    <slot />
  </div>
</div>

<style>
  .callout {
    border-left: 4px solid;
    border-radius: var(--radius-md);
    padding: var(--space-5);
    margin: var(--space-6) 0;
  }

  .callout-title {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    font-size: 0.9375rem;
    margin-bottom: var(--space-3);
  }

  .callout-icon {
    flex-shrink: 0;
  }

  .callout-content {
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .callout-content :global(p) {
    margin-bottom: var(--space-3);
  }

  .callout-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .callout-content :global(code) {
    background: var(--color-bg-tertiary);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.875em;
    font-family: var(--font-mono);
  }

  .callout-content :global(pre) {
    background: var(--color-bg-primary);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin: var(--space-4) 0;
    overflow-x: auto;
  }
</style>
