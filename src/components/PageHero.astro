---
import { siteConfig } from '../config.mjs';

interface Props {
  title: string;
  description?: string;
  isHome?: boolean;
  themeColor?: string;
}

const {
  title,
  description,
  isHome = false,
  themeColor = '0, 212, 224',
} = Astro.props;
---

<section class:list={['hero-section', { 'hero-home': isHome }]}>
  <div class="hero-bg">
    <div class="hero-glow" style={`background: radial-gradient(circle, rgba(${themeColor}, 0.12) 0%, transparent 70%);`}></div>
  </div>
  <div class="hero-content">
    <h1 class:list={['hero-title', { 'hero-title-home': isHome }]}>
      {title}
    </h1>
    {isHome && <p class="hero-subtitle">{siteConfig.description}</p>}
    {description && <p class="hero-desc">{description}</p>}
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 3.5rem 1.5rem 3rem;
    margin-bottom: 2.5rem;
    background: linear-gradient(
      135deg,
      rgba(0, 212, 224, 0.06) 0%,
      rgba(0, 212, 224, 0.02) 40%,
      transparent 100%
    );
  }

  .hero-home {
    padding: 4rem 1.5rem 3.5rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 500px;
    height: 500px;
    transform: translate(-50%, -50%);
  }

  .hero-home .hero-glow {
    width: 600px;
    height: 600px;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
    background: linear-gradient(135deg, var(--color-text-primary) 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-section {
      padding: 2.5rem 1rem 2rem;
    }
    .hero-home {
      padding: 3rem 1rem 2.5rem;
    }
    .hero-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>