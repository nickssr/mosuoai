---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <!-- 顶部光带 -->
  <div class="footer-glow-line"></div>

  <div class="footer-container">
    <!-- 主内容区 -->
    <div class="footer-main">
      <!-- 品牌区域 -->
      <div class="footer-brand">
        <a href="/" class="brand-logo">
