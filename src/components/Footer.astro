            </svg>
            Astro
          </a>
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid rgba(0, 212, 224, 0.1);
    background: linear-gradient(180deg, rgba(8, 12, 18, 0.98) 0%, rgba(4, 8, 14, 0.99) 100%);
    padding: var(--space-10) var(--space-6) var(--space-6);
    margin-top: auto;
    position: relative;
    overflow: hidden;
  }

  /* 顶部光带 */
  .footer-glow-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-primary) 50%, transparent 100%);
    opacity: 0.6;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  .footer-main {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-8);
  }

  /* Brand Section */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.3s ease;
  }

  .brand-logo:hover {
    transform: translateX(4px);
  }

  .logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, rgba(0, 212, 224, 0.12) 0%, rgba(0, 212, 224, 0.04) 100%);
    border-radius: 10px;
    border: 1px solid rgba(0, 212, 224, 0.15);
  }

  .brand-svg {
    width: 24px;
    height: 24px;
    color: var(--color-primary);
    filter: drop-shadow(0 0 6px rgba(0, 212, 224, 0.4));
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-tagline {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0;
    padding-left: 52px;
  }

  /* Links */
  .footer-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-link {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s ease;
    padding: var(--space-1) var(--space-2);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .link-dot {
    color: var(--color-border);
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .link-icon {
    width: 16px;
    height: 16px;
    opacity: 0.8;
  }

  .footer-link:hover .link-icon {
    opacity: 1;
  }

  /* Divider */
  .footer-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(0, 212, 224, 0.15) 50%, transparent 100%);
    margin: var(--space-6) 0;
  }

  /* Bottom Section */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .copyright {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin: 0;
  }

  .copyright-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .copyright-link:hover {
    color: var(--color-primary);
  }

  .tech-info {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: 0.8rem;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
  }

  .tech-label {
    opacity: 0.6;
    font-size: 0.75rem;
  }

  .tech-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1-5);
    padding: var(--space-1) var(--space-3);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.75rem;
    transition: all 0.25s ease;
  }

  .tech-badge:hover {
    background: rgba(0, 212, 224, 0.08);
    border-color: rgba(0, 212, 224, 0.2);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .tech-badge.astro:hover {
    background: rgba(255, 109, 53, 0.08);
    border-color: rgba(255, 109, 53, 0.2);
    color: #FF6D35;
  }

  .badge-icon {
    width: 14px;
    height: 14px;
    opacity: 0.7;
  }

  .tech-badge:hover .badge-icon {
    opacity: 1;
  }

  .tech-sep {
    color: var(--color-border);
    opacity: 0.4;
    font-size: 0.65rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer {
      padding: var(--space-8) var(--space-5) var(--space-5);
    }

    .footer-main {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-6);
    }

    .footer-brand {
      align-items: center;
    }

    .brand-tagline {
      padding-left: 0;
    }

    .footer-links {
      justify-content: center;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: var(--space-3);
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      gap: var(--space-1);
    }

    .link-dot {
      display: none;
    }

    .footer-link {
      padding: var(--space-1) var(--space-3);
      border-radius: 6px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .footer-link:hover {
      background: rgba(0, 212, 224, 0.08);
      border-color: rgba(0, 212, 224, 0.2);
    }

    .tech-info {
      flex-direction: column;
      gap: var(--space-2);
    }

    .tech-sep {
      display: none;
    }
  }
</style>
