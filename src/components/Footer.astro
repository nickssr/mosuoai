      </div>
    </div>

    <!-- 分隔线 -->
    <div class="footer-divider"></div>

    <!-- 底部信息 -->
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} <a href="/" class="copyright-link">摩索 AI</a>. All rights reserved.
      </p>
